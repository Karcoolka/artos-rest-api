{
  "name": "artos-rest-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "dev:client": "npm run dev --prefix client",
    "dev:all": "concurrently -n api,client -c blue,green \"npm run dev\" \"npm run dev:client\"",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=.env dist/server.js",
    "test": "vitest run --env-file=.env",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:functional": "vitest run tests/functional",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:wait": "node scripts/wait-for-db.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset": "docker compose down -v && docker compose up -d postgres && npm run db:wait && npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcrypt": "^6.0.0",
    "express": "^4.21.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.23",
    "@types/node": "^22.15.32",
    "@types/supertest": "^6.0.3",
    "concurrently": "^9.1.2",
    "prisma": "^6.9.0",
    "supertest": "^7.1.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
